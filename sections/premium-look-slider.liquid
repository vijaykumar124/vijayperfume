<style>
.looks-section {
  padding: 40px 0;
}

.looks-section.color-bg {
  background: var(--color-background);
  color: var(--color-foreground);
}

/* HEADING */
.looks-heading {
  text-align: center;
  margin-bottom: 40px;
}

/* MAIN WRAPPER (NEW) */
.looks-main {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40px;
  max-width: 1100px;
  margin: auto;
}

/* PREVIEW */
.looks-preview {
  flex: 0 0 var(--preview-width);
}

.looks-preview img {
  width: 100%;
  display: block;
}

/* PRODUCT */
.looks-product {
  flex: 0 0 var(--product-width);
  text-align: center;
}

.looks-product img {
  width: 120px;
}

/* BUTTON */
.looks-btn {
  display: inline-block;
  padding: 10px 20px;
  background: #000;
  color: #fff;
  text-decoration: none;
  margin-top: 10px;
}

/* SLIDER */
.looks-slider {
  position: relative;
}

/* ARROWS FIX */
.looks-slider .slick-prev,
.looks-slider .slick-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;

  width: 36px;
  height: 36px;

  border-radius: 50%;
  background: #fff;
  color: #000;

  display: flex !important;
  align-items: center;
  justify-content: center;
}

.looks-slider .slick-prev {
  left: 10px;
}

.looks-slider .slick-next {
  right: 10px;
}

/* DOTS */
.slick-dots li button:before {
  color: #000;
}

/* ANIMATION */
.slick-slide {
  opacity: 0;
  transition: 0.4s;
}
.slick-active {
  opacity: 1;
}

/* MOBILE */
@media(max-width:768px){
  .looks-main {
    flex-direction: column;
  }

  .looks-preview,
  .looks-product {
    flex: 100%;
  }

  .looks-slider .slick-prev,
  .looks-slider .slick-next {
    display: none !important;
  }
}
</style>

<div class="looks-section color-{{ section.settings.color_scheme }}"
     style="--preview-width: {{ section.settings.preview_width }}%;
            --product-width: {{ section.settings.product_width }}%;">

  <!-- HEADING -->
  <div class="looks-heading">
    <h2 style="font-size: {{ section.settings.heading_size }}px;">
      {{ section.settings.heading }}
    </h2>
    <p>{{ section.settings.description }}</p>
  </div>

  <!-- MAIN FIXED LAYOUT -->
  <div class="looks-main">

    <!-- LEFT PREVIEW (STATIC) -->
    <div class="looks-preview">
      <img id="previewImage" src="">
    </div>

    <!-- RIGHT PRODUCT SLIDER -->
    <div class="looks-product">
      <div class="looks-slider">

        {% for block in section.blocks %}
          {% assign product = block.settings.product %}

          <div class="slide-item"
               data-preview="{% if product.images.size > 1 %}{{ product.images[1] | image_url }}{% else %}{{ product.featured_image | image_url }}{% endif %}">

            <img src="{{ product.featured_image | image_url }}">
            <h4>{{ product.title }}</h4>
            <p>{{ product.price | money }}</p>

            <a href="{{ product.url }}" class="looks-btn">
              {{ block.settings.button_text }}
            </a>

          </div>

        {% endfor %}

      </div>
    </div>

  </div>

</div>

<script>
$(document).ready(function(){

  var $slider = $('.looks-slider');

  $slider.slick({
    slidesToShow: 1,
    arrows: true,
    dots: true,
    fade: true,
    speed: 600
  });

  function updatePreview(index){
    var slide = $slider.find('.slick-slide[data-slick-index="'+index+'"] .slide-item');
    var img = slide.data('preview');
    $('#previewImage').attr('src', img);
  }

  // INIT FIX
  setTimeout(function(){
    updatePreview(0);
  }, 200);

  $slider.on('afterChange', function(event, slick, currentSlide){
    updatePreview(currentSlide);
  });

});
</script>

{% schema %}
{
  "name": "Premium Look Slider",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR LOOKS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Shop"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "preview_width",
      "label": "Preview Width (%)",
      "min": 40,
      "max": 80,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "product_width",
      "label": "Product Width (%)",
      "min": 20,
      "max": 50,
      "step": 5,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "VIEW PRODUCT"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Look Slider"
    }
  ]
}
{% endschema %}