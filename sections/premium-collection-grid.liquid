<style>
.collection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
 
}

.collection-card {
  position: relative;
  overflow: hidden;
}

.collection-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

/* ZOOM EFFECT */
.collection-card:hover img {
  transform: scale(var(--zoom));
}

/* CONTENT */
.collection-content {
  position: absolute;
  transform: translate(-50%, -50%);
}

/* BUTTON */
.collection-btn {
  padding: 10px 20px;
  border: 1px solid #fff;
  color: #fff;
  text-decoration: none;
  font-size: 12px;
  letter-spacing: 1px;
  transition: 0.3s;
}

.collection-btn:hover {
  background: #fff;
  color: #000;
}

/* MOBILE */
@media(max-width: 768px){
  .collection-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<div class="collection-grid">

  {% for block in section.blocks %}
    
    {% assign collection = block.settings.collection %}
    
    <div class="collection-card" style="--zoom: {{ block.settings.zoom }};">
      
      {% if collection != blank and collection.featured_image != blank %}
        <img src="{{ collection.featured_image | image_url }}" alt="">
      {% endif %}

      <!-- CONTENT -->
      <div 
        class="collection-content"
        style="
          top: {{ block.settings.pos_y }}%;
          left: {{ block.settings.pos_x }}%;
        "
      >
        {% if block.settings.button_text != blank and collection != blank %}
          <a href="{{ collection.url }}" class="button">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>

    </div>

  {% endfor %}

</div>

{% schema %}
{
  "name": "Premium Collection Grid",
  "settings": [],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "SHOP NOW"
        },
        {
          "type": "range",
          "id": "pos_x",
          "label": "Button Horizontal Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "pos_y",
          "label": "Button Vertical Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 80
        },
        {
          "type": "range",
          "id": "zoom",
          "label": "Hover Zoom Scale",
          "min": 1,
          "max": 2,
          "step": 0.1,
          "default": 1.1
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Collection Grid",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}