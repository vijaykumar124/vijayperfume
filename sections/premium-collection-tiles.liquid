      "min": 100,
      "max": 130,
      "step": 1,
      "default": 108,
      "info": "100 = no zoom, 108 = 8% zoom in"
    },
    {
      "type": "header",
      "content": "Button (default for all cards)"
    },
    {
      "type": "text",
      "id": "default_btn_label",
      "label": "Default Button Label",
      "default": "View Products"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Text Color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Button Border Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Arrow Buttons"
    },
    {
      "type": "color",
      "id": "arrow_bg",
      "label": "Arrow Background",
      "default": "rgba(255,255,255,0.85)"
    },
    {
      "type": "color",
      "id": "arrow_border",
      "label": "Arrow Border Color",
      "default": "#dddddd"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow Icon Color",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "arrow_hover_bg",
      "label": "Arrow Hover Background",
      "default": "#1a1a2e"
    },
    {
      "type": "header",
      "content": "Slider Threshold"
    },
    {
      "type": "range",
      "id": "slider_threshold",
      "label": "Activate Slider When Cards >",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "info": "If you have more blocks than this number, slick slider activates automatically"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (overrides collection image)"
        },
        {
          "type": "text",
